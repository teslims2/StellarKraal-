# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform lock file (commit this for reproducible provider versions)
# .terraform.lock.hcl  <-- intentionally kept

# Variable files that may contain secrets
*.tfvars.json
# Keep the example files but ignore real secret overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Generated plan files
*.tfplan

# Plugin cache directory
.terraform/
