{
  "name": "stellarkraal-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "jest --passWithNoTests",
    "test:contrast": "node ./scripts/contrast-audit.js",
    "test:a11y": "playwright test -c playwright-a11y.config.ts",
    "test:e2e": "playwright test -c playwright.e2e.config.ts",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "focus-trap-react": "^12.0.3",
    "framer-motion": "^12.42.2",
    "next": "14.2.35",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.1.1",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "^7.0.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom",
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.tsx",
      "**/*.test.tsx",
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx",
            "rootDir": ".",
            "moduleResolution": "node",
            "ignoreDeprecations": "6.0"
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@stellar)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.test.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/app/layout.tsx",
      "!src/app/page.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 70,
        "statements": 70
      }
    }
  }
}
